{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "postinstall": "prisma generate",
    "vercel-build": "pnpm --filter @quizforge/shared build && prisma generate && esbuild api/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/bundle.js --external:@prisma/client",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src test --ext .ts",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "prisma": "prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.957.0",
    "@aws-sdk/s3-request-presigner": "^3.957.0",
    "@prisma/client": "^6.19.0",
    "@quizforge/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^9.0.1",
    "sanitize-html": "^2.17.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.12.3",
    "@types/nodemailer": "^7.0.4",
    "@types/sanitize-html": "^2.16.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.0",
    "ts-jest": "^29.4.6",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
